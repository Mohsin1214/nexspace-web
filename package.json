{
  "name": "nexspace-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev":              "next dev",
    "build":            "next build",
    "start":            "next start",
    "lint":             "next lint",
    "lint:fix":         "next lint --fix",
    "type-check":       "tsc --noEmit",
    "db:generate":      "prisma generate",
    "db:push":          "prisma db push",
    "db:migrate":       "prisma migrate dev",
    "db:migrate:prod":  "prisma migrate deploy",
    "db:studio":        "prisma studio",
    "db:seed":          "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.15.0",
    "next":           "14.2.4",
    "nodemailer":     "^6.9.14",
    "react":          "^18.3.1",
    "react-dom":      "^18.3.1",
    "zod":            "^3.23.8"
  },
  "devDependencies": {
    "@types/node":       "^20.14.9",
    "@types/nodemailer": "^6.4.15",
    "@types/react":      "^18.3.3",
    "@types/react-dom":  "^18.3.0",
    "autoprefixer":      "^10.4.19",
    "eslint":            "^8.57.0",
    "eslint-config-next":"14.2.4",
    "postcss":           "^8.4.39",
    "prisma":            "^5.15.0",
    "tailwindcss":       "^3.4.4",
    "ts-node":           "^10.9.2",
    "typescript":        "^5.5.3"
  }
}
