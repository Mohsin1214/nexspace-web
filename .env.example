# ============================================================
# NexSpace Website — Environment Variables Template
# Copy this file to .env.local for local development
# NEVER commit .env.local to Git
# ============================================================

# --- Database (PostgreSQL) ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/nexspace_db"

# --- Next.js ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# --- Email (for Contact Form) ---
# Option A: Gmail SMTP
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-gmail-app-password"
CONTACT_EMAIL_TO="your-email@gmail.com"

# Option B: Resend (recommended)
# RESEND_API_KEY="re_xxxxxxxxxxxxxxxx"

# --- App Config ---
NEXT_PUBLIC_SITE_URL="https://yourdomain.com"
NEXT_PUBLIC_SITE_NAME="NexSpace"
NEXT_PUBLIC_GA_ID=""   # Google Analytics (optional)
